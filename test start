<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Pocket Mine Instant Demo</title>
  <style>
    :root{font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#eaf4ff;background:#07111f}*{box-sizing:border-box}body{margin:0;min-height:100vh;background:radial-gradient(circle at 20% 0,#1677ff66,transparent 32rem),#07111f}.wrap{width:min(1120px,calc(100% - 28px));margin:auto;padding:28px 0}.card{background:linear-gradient(145deg,#10213add,#0a1424f2);border:1px solid #ffffff18;border-radius:28px;box-shadow:0 24px 70px #0009;padding:22px}.hero{margin-bottom:18px;position:relative;overflow:hidden}.hero:after{content:'PM';position:absolute;right:20px;top:-25px;font-size:140px;font-weight:900;color:#fff08}.eyebrow{letter-spacing:.18em;text-transform:uppercase;color:#72e4ff;font-size:12px;font-weight:800}h1{font-size:clamp(48px,9vw,104px);line-height:.88;margin:8px 0}.lead{max-width:760px;color:#bfd1e7;font-size:19px}.grid{display:grid;grid-template-columns:1fr 1.35fr 1fr;gap:18px}.queue{display:grid;gap:10px}.battery{border:1px solid #ffffff16;background:#ffffff0a;color:inherit;border-radius:18px;padding:14px;text-align:left;display:grid;grid-template-columns:auto 1fr;gap:3px 10px;width:100%;cursor:pointer}.battery em{grid-column:2;color:#a8b8ce;font-style:normal}.battery.active{outline:2px solid #72e4ff}.battery.review{border-color:#ffd166aa}.battery.isolate{border-color:#ff4d6d;background:#ff4d6d1a}.device{height:255px;border-radius:24px;background:linear-gradient(160deg,#06101f,#14365e);display:grid;place-items:center;position:relative;overflow:hidden;border:1px solid #78dfff44}.lens{position:absolute;inset:24px;border:1px dashed #9ee7ff66;border-radius:18px}.art{font-size:72px;letter-spacing:-12px;filter:drop-shadow(0 0 24px #62d5ff)}.scanline{position:absolute;left:0;right:0;height:3px;background:#65f8ff;box-shadow:0 0 28px #65f8ff;opacity:0;transform:translateY(-135px)}.scanning .scanline{opacity:1;animation:scan .7s linear infinite}@keyframes scan{to{transform:translateY(135px)}}button.main{border:0;border-radius:14px;padding:13px 18px;font-weight:900;color:#05101d;background:#72e4ff;margin:12px 8px 0 0}.main.green{background:#a7f3a3}.result,.prize{border:1px solid #ffffff18;border-radius:18px;background:#ffffff10;padding:16px;margin-top:14px}.result.isolate{border-color:#ff4d6d}.result.review{border-color:#ffd166}.result.safe{border-color:#7df3a1}pre{overflow:auto;background:#020815;color:#b8f7ce;border-radius:14px;padding:12px}.meter{height:14px;border-radius:999px;background:#ffffff12;overflow:hidden}.meter span{display:block;height:100%;background:linear-gradient(90deg,#72e4ff,#a7f3a3)}.hint{color:#9fb4cf}@media(max-width:900px){.grid{grid-template-columns:1fr}.wrap{width:min(100% - 18px,720px);padding:14px 0}}
  </style>
</head>
<body><main class="wrap" id="app"></main><script>
const batteries=[{id:'A12',owner:'Gate 18',label:'10000mAh 3.7V',condition:'clean label / no deformation'},{id:'B07',owner:'Intl transfer',label:'26800mAh 3.7V',condition:'scratched shell / warm'},{id:'C31',owner:'Security lane 4',label:'No label',condition:'swollen corner / dented'},{id:'E90',owner:'Lost & found',label:'32000mAh 3.7V',condition:'burn mark / cracked case'}];
const prizes=[['S','Rare Earth Recovery Pass','リサイクル資源トークンを付与。'],['A','Green Boarding Badge','空港サステナビリティ参加バッジを発行。'],['B','Coffee Coupon Mock','提携店舗やマイル連携のデモ。']];
const state={selected:batteries[0],result:null,scanning:false,count:9,reward:null};
function cap(label){const m=label.match(/(\d{4,6})\s*mAh/i)?.[1],v=label.match(/(\d+(?:\.\d+)?)\s*V/i)?.[1];return m&&v?Math.round(Number(m)*Number(v)/100)/10:null}
function analyze(b){const t=(b.label+' '+b.condition).toLowerCase(), wh=cap(b.label), signs=[]; if(/swollen/.test(t))signs.push('膨張'); if(/burn/.test(t))signs.push('焦げ跡'); if(/crack/.test(t))signs.push('外装割れ'); if(/dent/.test(t))signs.push('強いへこみ'); if(/warm/.test(t))signs.push('発熱'); if(/no label/.test(t))signs.push('ラベル不明'); let verdict='持ち込み可能',level='safe',action='通常レーンへ戻す'; if((wh&&wh>100)||signs.includes('発熱')||signs.includes('ラベル不明')){verdict='確認が必要';level='review';action='係員確認・航空会社ルール照合'} if(signs.some(s=>['膨張','焦げ跡','外装割れ'].includes(s))){verdict='今すぐ隔離';level='isolate';action='耐火ボックスへ回収し、資源化トレーサビリティを開始'} return {...b,wh,signs,verdict,level,action}}
function reward(){if(state.count%10!==0)return{win:false,remaining:10-state.count%10};const p=prizes[0];return{win:true,tier:p[0],name:p[1],message:p[2]}}
function render(){const rows=batteries.map(analyze);app.innerHTML=`<section class="hero card"><p class="eyebrow">Instant runnable HTML demo</p><h1>Pocket Mine</h1><p class="lead">このファイルだけで試せる、空港向けAIモバイルバッテリー判定デモ。10回目の回収でリワード演出が出ます。</p></section><section class="grid"><aside class="card queue"><h2>Live battery queue</h2>${rows.map(b=>`<button class="battery ${b.level} ${state.selected.id===b.id?'active':''}" data-id="${b.id}"><strong>${b.id}</strong><span>${b.owner}</span><em>${b.verdict}</em></button>`).join('')}</aside><section class="card"><div class="device ${state.scanning?'scanning':''}"><div class="lens"></div><div class="art">▭▭▭</div><div class="scanline"></div></div><h2>${state.selected.label}</h2><p>${state.selected.condition}</p><button class="main" id="scan">AI判定を実行</button><button class="main green" id="collect">回収して抽選</button>${state.result?view(state.result):'<p class="hint">キューを選択してAI判定を開始。</p>'}</section><aside class="card"><p class="eyebrow">Collection Reward</p><h2>10人に1人リワード</h2><div class="meter"><span style="width:${state.count%10*10}%"></span></div><p>${state.count%10}/10 回収済み</p>${state.reward?prizeView():'<p class="hint">回収ボタンで即デモできます。</p>'}</aside></section>`;bind()}
function view(r){return`<div class="result ${r.level}"><h3>${r.verdict}</h3><p>${r.action}</p><pre>${JSON.stringify({flightSafety:r.verdict,wh:r.wh??'unknown',riskSignals:r.signs,nextAction:r.action},null,2)}</pre></div>`}
function prizeView(){return state.reward.win?`<div class="prize"><strong>🎉 ${state.reward.tier}賞 ${state.reward.name}</strong><p>${state.reward.message}</p></div>`:`<p class="hint">あと${state.reward.remaining}回収で抽選。</p>`}
function bind(){document.querySelectorAll('.battery').forEach(x=>x.onclick=()=>{state.selected=batteries.find(b=>b.id===x.dataset.id);state.result=null;render()});document.querySelector('#scan').onclick=()=>{state.scanning=true;render();setTimeout(()=>{state.result=analyze(state.selected);state.scanning=false;render()},550)};document.querySelector('#collect').onclick=()=>{state.count++;state.reward=reward();render()}}
render();
</script></body></html>
